{
  "expo": {
    "name": "AgroSat",
    "slug": "agrosat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "agrosat",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrosat.com"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#060d09",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.agrosat.com",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      "expo-font",
      "expo-splash-screen"
    ],
    "extra": {
      "commitHash": "dev",
      "router": {},
      "eas": {
        "projectId": "505e85e6-614d-4ea3-9fba-489c58d6249d"
      }
    }
  }
}
