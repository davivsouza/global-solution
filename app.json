{
  "expo": {
    "name": "AgroSat",
    "slug": "agrosat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "agrosat",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.globalsolution.agrosat"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#060d09",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.globalsolution.agrosat"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      "expo-font",
      "expo-splash-screen"
    ],
    "extra": {
      "commitHash": "dev"
    }
  }
}
